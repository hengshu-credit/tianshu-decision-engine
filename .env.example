# 后端会自动读取仓库根目录 .env；复制后替换为当前环境的独立强密码，请勿提交真实凭据。
# 生产环境应使用 Secret/KMS 或系统环境变量覆盖 .env 中的同名配置。
MYSQL_ROOT_PASSWORD=replace-with-a-strong-mysql-password
MYSQL_DATABASE=rule_engine
REDIS_PASSWORD=replace-with-a-strong-redis-password
REDIS_HOST=localhost
REDIS_PORT=6379

# rule-engine-server 使用的数据库账号建议单独创建并按最小权限授权。
MYSQL_USERNAME=rule_engine_app
MYSQL_PASSWORD=replace-with-a-strong-app-password

# 至少 32 个字符、非重复且仅属于当前环境。
RULE_AUTH_MASTER_KEY=replace-with-a-private-random-key-of-at-least-32-characters
RULE_AUTH_ACTIVE_KEY_ID=v2

CONSOLE_USERNAME=admin
# 默认按 BCrypt 校验；这里填写 BCrypt 哈希，不填写明文密码。
CONSOLE_PASSWORD=$2a$10$replace-with-a-valid-bcrypt-hash
CONSOLE_PASSWORD_ENCODING=BCRYPT
CORS_ALLOWED_ORIGIN_PATTERNS=https://console.example.com
SESSION_COOKIE_SECURE=true
